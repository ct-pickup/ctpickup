# --- Public (browser + server) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Canonical site URL for Stripe return URLs and server-side API self-fetch.
# Set in Vercel to https://your-domain.com (no trailing slash).
# Also align Supabase Auth "Site URL" and redirect URLs with this origin.
NEXT_PUBLIC_SITE_URL=

# Auth email (8-digit OTP) is configured in Supabase Dashboard: Auth → SMTP (e.g. Resend),
# sender login@ctpickup.net, and email templates — not via env vars here. See docs/supabase-auth-email.md.

# --- Server only ---
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (tournament captain checkout, pickup field fees) — server-only
# Production: sk_live_... , whsec_... from LIVE mode in Dashboard; use matching webhook endpoint URL.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Optional; required if you add Stripe.js / Elements. Production must be pk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Optional override; default matches stripe package if unset
# STRIPE_API_VERSION=

# OpenAI (tournament intake chat flow, help assistant)
OPENAI_API_KEY=
# Optional model IDs (defaults are set in code)
# OPENAI_MODEL=           # tournament intake; default gpt-5.2
# OPENAI_HELP_MODEL=      # /api/help/chat; falls back to OPENAI_MODEL then gpt-5-mini

# Twilio (optional SMS — server-only; never expose to the client)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# Sender: use a phone number OR a Messaging Service SID (not both required in env; code prefers Messaging Service when set)
# TWILIO_PHONE_NUMBER=+15551234567
# Legacy alias still supported:
# TWILIO_FROM_NUMBER=
# TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxx
# Public origin Twilio will POST to — must match the webhook URL used in Twilio Console (fixes signature validation on Vercel)
# NEXT_PUBLIC_SITE_URL=https://your-domain.com
# If your app URL differs from the URL Twilio calls (e.g. some proxies), set explicitly:
# TWILIO_WEBHOOK_BASE_URL=https://your-domain.com
# Optional: default status callback URL for all outbound sends (https in production)
# TWILIO_STATUS_CALLBACK_URL=https://your-domain.com/api/twilio/status

# Local tunnel only: never in production
# TWILIO_SKIP_SIGNATURE_VALIDATION=1

# Vercel sets automatically in production
# VERCEL_URL=

# Vercel Cron: must match the Authorization Bearer sent by Vercel (configure in project env)
CRON_SECRET=
