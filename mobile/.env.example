# Same Supabase project as the Next.js app (Auth → URL allowlist must include your Expo scheme / EAS URLs).
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Deployed Next.js origin (no trailing slash). Used for /api/pickup/public, /api/mobile/push-token, /api/auth/email-exists.
EXPO_PUBLIC_SITE_URL=https://your-domain.com

# Optional: after `eas init`, paste project ID so Expo push tokens work outside Expo Go.
# Also add the same EXPO_PUBLIC_* keys in Expo → Project → Environment variables for EAS Build.
# EXPO_PUBLIC_EAS_PROJECT_ID=
