"use client";

import PageTop from "@/components/PageTop";

import Link from "next/link";
import { useEffect, useMemo, useState } from "react";
import { createClient } from "@supabase/supabase-js";

const supabase = createClient(
  process.env.NEXT_PUBLIC_SUPABASE_URL!,
  process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY!
);

type PublicStatus = {
  tournament: {
    id: string;
    title: string;
    targetTeams: number;
    officialThreshold: number;
    maxTeams: number;
  };
  claimedTeams: number;
  confirmedTeams: number;
  official: boolean;
  full: boolean;
};

type Prelim = { fullName: string; instagram: string };

function normIg(s: string) {
  return s.trim().replace(/^@/, "").replace(/\s+/g, "");
}

export default function TournamentPage() {
  const [status, setStatus] = useState<PublicStatus | null>(null);
  const [loading, setLoading] = useState(true);

  const [sessionToken, setSessionToken] = useState<string | null>(null);

  const [modalOpen, setModalOpen] = useState(false);
  const [submitting, setSubmitting] = useState(false);

  const [captainName, setCaptainName] = useState("");
  const [captainIg, setCaptainIg] = useState("");
  const [teamName, setTeamName] = useState("");
  const [expectedPlayers, setExpectedPlayers] = useState(10);

  const [confirmIdentity, setConfirmIdentity] = useState(false);

  const [prelimRoster, setPrelimRoster] = useState<Prelim[]>([]);
  const [claimDone, setClaimDone] = useState(false);

  const [payBusy, setPayBusy] = useState(false);
  const [error, setError] = useState<string | null>(null);

  async function refreshPublic() {
    setLoading(true);
    try {
      const r = await fetch("/api/tournament/public");
      const j = await r.json();
      setStatus(j);
    } finally {
      setLoading(false);
    }
  }

  useEffect(() => {
    refreshPublic();
    (async () => {
      const s = await supabase.auth.getSession();
      setSessionToken(s.data.session?.access_token || null);
    })();
  }, []);

  const progress = useMemo(() => {
    if (!status) return 0;
    return Math.min(1, status.confirmedTeams / status.tournament.maxTeams);
  }, [status]);

  const progressFillClass = useMemo(() => {
    if (!status) return "bg-white/10";
    if (status.official || status.full) return "bg-emerald-500/40";
    return "bg-gradient-to-r from-red-500/40 via-amber-400/35 to-emerald-500/35";
  }, [status]);

  const headline = useMemo(() => {
    if (!status) return "";
    if (status.full) return "Tournament is full.";
    if (status.official) return "Tournament is official.";
    return "Tournament is in the planning phase.";
  }, [status]);

  const isLoggedIn = !!sessionToken;

  function openClaimModal() {
    setError(null);
    setClaimDone(false);
    setConfirmIdentity(false);
    setModalOpen(true);
  }

  function addPrelimRow() {
    setPrelimRoster((r) => [...r, { fullName: "", instagram: "" }]);
  }

  function updatePrelim(i: number, key: "fullName" | "instagram", value: string) {
    setPrelimRoster((r) => r.map((x, idx) => (idx === i ? { ...x, [key]: value } : x)));
  }

  function removePrelim(i: number) {
    setPrelimRoster((r) => r.filter((_, idx) => idx !== i));
  }

  async function submitClaim() {
    if (!sessionToken) return;
    setSubmitting(true);
    setError(null);

    try {
      const payload = {
        captainName: captainName.trim(),
        captainInstagram: normIg(captainIg).toLowerCase(),
        teamName: teamName.trim(),
        expectedPlayers,
        prelimRoster: prelimRoster.map((p) => ({
          fullName: p.fullName.trim(),
          instagram: normIg(p.instagram).toLowerCase(),
        })),
      };

      const r = await fetch("/api/tournament/captain/submit-claim", {
        method: "POST",
        headers: {
          Authorization: `Bearer ${sessionToken}`,
          "Content-Type": "application/json",
        },
        body: JSON.stringify(payload),
      });

      const j = await r.json();
      if (!r.ok) {
        setError(j?.error || "Could not submit claim.");
        return;
      }

      setClaimDone(true);
      await refreshPublic();
    } finally {
      setSubmitting(false);
    }
  }

  async function goToPayment() {
    if (!sessionToken) return;
    setPayBusy(true);
    setError(null);
    try {
      const r = await fetch("/api/stripe/create-checkout-session", {
        method: "POST",
        headers: { Authorization: `Bearer ${sessionToken}` },
      });
      const j = await r.json();
      if (!r.ok) {
        setError(j?.error || "Could not start checkout.");
        return;
      }
      window.location.href = j.url;
    } finally {
      setPayBusy(false);
    }
  }

  return (
    <main className="min-h-screen bg-black text-white">
      <PageTop title="TOURNAMENT" />
      <div className="mx-auto max-w-5xl px-6 py-14 space-y-10">

        {/* Public status */}
        <section className="rounded-2xl border border-white/10 bg-white/[0.03] p-8 space-y-5">
          <div className="text-xl font-semibold uppercase tracking-wide text-white/90">{headline}</div>

          <div className="grid gap-3 sm:grid-cols-2">
            <div className="rounded-xl border border-white/10 bg-black/30 p-5">
              <div className="text-xs uppercase tracking-widest text-white/55">Claimed captain spots</div>
              <div className="mt-2 text-2xl font-semibold text-white/90">
                {status ? `${status.claimedTeams} / ${status.tournament.targetTeams}` : "—"}
              </div>
            </div>

            <div className="rounded-xl border border-white/10 bg-black/30 p-5">
              <div className="text-xs uppercase tracking-widest text-white/55">Confirmed teams</div>
              <div className="mt-2 text-2xl font-semibold text-white/90">
                {status ? `${status.confirmedTeams} / ${status.tournament.maxTeams}` : "—"}
              </div>
              <div className="mt-2 text-xs text-white/55">
                Tournament becomes official at {status?.tournament.officialThreshold ?? 8} confirmed.
              </div>
            </div>
          </div>

          <div className="space-y-2">
            <div className="h-3 w-full rounded-full border border-white/10 bg-black/40 overflow-hidden">
              <div className={`h-full ${progressFillClass}`} style={{ width: `${Math.round(progress * 100)}%` }} />
            </div>
            <div className="text-xs text-white/55">Progress reflects confirmed teams only.</div>
          </div>
        </section>

        {/* Captain CTA */}
        <section className="rounded-2xl border border-white/10 bg-white/[0.03] p-8 space-y-4">
          <div className="text-lg font-semibold uppercase tracking-wide text-white/90">Captain-based entry</div>

          <div className="text-sm text-white/75 max-w-3xl">
            Captains claim a temporary hold first. Teams are only confirmed after payment, eligibility review, roster
            verification, and final approval.
          </div>

          {!isLoggedIn ? (
            <Link href="/login" className="inline-flex items-center justify-center rounded-md px-5 py-3 text-sm font-semibold bg-white text-black w-full sm:w-auto">
              LOG IN
            </Link>
          ) : (
            <button
              type="button"
              onClick={openClaimModal}
              className="inline-flex items-center justify-center rounded-md px-5 py-3 text-sm font-semibold bg-white text-black w-full sm:w-auto"
            >
              CAPTAIN A TEAM
            </button>
          )}

          {error ? <div className="text-sm text-red-200">{error}</div> : null}
        </section>

        {/* Modal */}
        {modalOpen && (
          <div className="fixed inset-0 z-50 flex items-center justify-center bg-black/75 px-6">
            <div className="w-full max-w-2xl rounded-2xl border border-white/10 bg-black p-7">
              <div className="flex items-start justify-between gap-6">
                <div>
                  <div className="text-xl font-semibold uppercase tracking-wide text-white/90">
                    Claim Your Captain Spot
                  </div>
                  <div className="mt-2 text-sm text-white/75">
                    Claiming a captain slot reserves one potential team place for this tournament. This does not fully confirm your team.
                    <br />
                    All players must still be individually registered and verified before the final deadline.
                  </div>
                </div>

                <button
                  type="button"
                  onClick={() => setModalOpen(false)}
                  className="text-sm text-white/70 hover:text-white hover:underline underline-offset-4"
                >
                  Close
                </button>
              </div>

              {!claimDone ? (
                <div className="mt-6 space-y-6">
                  {/* Captain info */}
                  <div className="rounded-xl border border-white/10 bg-white/[0.03] p-5 space-y-4">
                    <div className="text-sm font-semibold uppercase tracking-wide text-white/80">
                      Captain info
                    </div>

                    <div className="grid gap-3 sm:grid-cols-2">
                      <input
                        value={captainName}
                        onChange={(e) => setCaptainName(e.target.value)}
                        placeholder="Full name"
                        className="w-full rounded-xl border border-white/15 bg-black px-4 py-3 text-sm text-white placeholder:text-white/35 outline-none focus:border-white/25"
                      />
                      <input
                        value={captainIg}
                        onChange={(e) => setCaptainIg(e.target.value)}
                        placeholder="Instagram handle"
                        className="w-full rounded-xl border border-white/15 bg-black px-4 py-3 text-sm text-white placeholder:text-white/35 outline-none focus:border-white/25"
                      />
                    </div>

                    <label className="flex items-center gap-3 text-sm text-white/75">
                      <input
                        type="checkbox"
                        checked={confirmIdentity}
                        onChange={(e) => setConfirmIdentity(e.target.checked)}
                      />
                      Is this your full name and Instagram handle?
                    </label>
                  </div>

                  {/* Team info */}
                  <div className="rounded-xl border border-white/10 bg-white/[0.03] p-5 space-y-4">
                    <div className="text-sm font-semibold uppercase tracking-wide text-white/80">
                      Team info
                    </div>

                    <div className="grid gap-3 sm:grid-cols-2">
                      <input
                        value={teamName}
                        onChange={(e) => setTeamName(e.target.value)}
                        placeholder="Team name"
                        className="w-full rounded-xl border border-white/15 bg-black px-4 py-3 text-sm text-white placeholder:text-white/35 outline-none focus:border-white/25"
                      />
                      <input
                        type="number"
                        value={expectedPlayers}
                        onChange={(e) => setExpectedPlayers(Number(e.target.value))}
                        min={5}
                        max={25}
                        placeholder="Expected players"
                        className="w-full rounded-xl border border-white/15 bg-black px-4 py-3 text-sm text-white placeholder:text-white/35 outline-none focus:border-white/25"
                      />
                    </div>

                    <div className="text-xs text-white/55">
                      Optional: early roster entries (preliminary only). These do not count as verified registration.
                    </div>

                    <div className="space-y-3">
                      {prelimRoster.map((p, i) => (
                        <div key={i} className="grid gap-2 sm:grid-cols-5">
                          <input
                            value={p.fullName}
                            onChange={(e) => updatePrelim(i, "fullName", e.target.value)}
                            placeholder="Full name"
                            className="sm:col-span-2 rounded-xl border border-white/15 bg-black px-4 py-3 text-sm text-white placeholder:text-white/35 outline-none focus:border-white/25"
                          />
                          <input
                            value={p.instagram}
                            onChange={(e) => updatePrelim(i, "instagram", e.target.value)}
                            placeholder="Instagram"
                            className="sm:col-span-2 rounded-xl border border-white/15 bg-black px-4 py-3 text-sm text-white placeholder:text-white/35 outline-none focus:border-white/25"
                          />
                          <button
                            type="button"
                            onClick={() => removePrelim(i)}
                            className="rounded-xl border border-white/15 bg-black px-4 py-3 text-sm text-white/80 hover:bg-white/[0.04]"
                          >
                            Remove
                          </button>
                        </div>
                      ))}
                      <button
                        type="button"
                        onClick={addPrelimRow}
                        className="text-sm text-white/70 hover:text-white hover:underline underline-offset-4"
                      >
                        Add early roster entry
                      </button>
                    </div>
                  </div>

                  <div className="flex flex-wrap gap-3">
                    <button
                      type="button"
                      onClick={submitClaim}
                      disabled={!confirmIdentity || submitting}
                      className="rounded-md bg-white px-5 py-2.5 text-sm font-semibold text-black disabled:opacity-50"
                    >
                      {submitting ? "Submitting…" : "Submit"}
                    </button>
                    <button
                      type="button"
                      onClick={() => setModalOpen(false)}
                      className="rounded-md border border-white/15 bg-black px-5 py-2.5 text-sm font-semibold text-white/85 hover:bg-white/[0.04]"
                    >
                      Cancel
                    </button>
                  </div>
                </div>
              ) : (
                <div className="mt-6 space-y-5">
                  <div className="rounded-xl border border-white/10 bg-white/[0.03] p-6 text-sm text-white/80 whitespace-pre-line">
                    Your captain interest has been recorded. Your team spot is not confirmed yet. Confirmation only happens after payment, eligibility review, roster verification, and final approval.
                  </div>

                  <div className="flex flex-wrap gap-3">
                    <button
                      type="button"
                      onClick={goToPayment}
                      disabled={payBusy}
                      className="rounded-md bg-white px-5 py-2.5 text-sm font-semibold text-black disabled:opacity-50"
                    >
                      {payBusy ? "Starting checkout…" : "Proceed to payment ($250)"}
                    </button>

                    <button
                      type="button"
                      onClick={() => setModalOpen(false)}
                      className="rounded-md border border-white/15 bg-black px-5 py-2.5 text-sm font-semibold text-white/85 hover:bg-white/[0.04]"
                    >
                      Close
                    </button>
                  </div>

                  <div className="text-xs text-white/55">
                    Payment window: 36 hours from payment request. If payment is not received in time, the captain hold is released.
                    No refunds within 48 hours of kickoff.
                  </div>
                </div>
              )}

              {error ? <div className="mt-4 text-sm text-red-200">{error}</div> : null}
            </div>
          </div>
        )}
      </div>
    </main>
  );
}
